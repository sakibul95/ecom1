    {
      "name": "Admin — Orders",
      "description": "Key-gated endpoint for fetching all orders.\nRequires Authorization: Bearer {{adminApiKey}}",
      "item": [
        {
          "name": "GET all orders",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminApiKey}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/orders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "orders"]
            },
            "description": "Returns first page of all orders (default pageSize 50), newest first."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Body has pagination fields', () => {",
                  "  const d = pm.response.json().data;",
                  "  pm.expect(d).to.have.property('orders');",
                  "  pm.expect(d).to.have.property('total');",
                  "  pm.expect(d).to.have.property('page');",
                  "  pm.expect(d).to.have.property('pageSize');",
                  "  pm.expect(d.orders).to.be.an('array');",
                  "  pm.expect(d.page).to.equal(1);",
                  "  pm.expect(d.pageSize).to.equal(50);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
