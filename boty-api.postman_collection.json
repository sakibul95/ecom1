{
  "info": {
    "name": "Boty API",
    "_postman_id": "boty-api-collection-v1",
    "description": "Complete API collection for the Boty e-commerce project.\n\n**Setup:**\n1. Set the `baseUrl` variable to your server URL (default: `http://localhost:3000`).\n2. Set `adminApiKey` to the value of `ADMIN_API_KEY` from your `.env.local`.\n3. Set `productId` to a slug that exists in your database for product/order tests.\n\n**Folders:**\n- Products — public endpoints\n- Orders — public order creation\n- Admin / Products — key-gated product upload\n- Admin / Orders — key-gated orders list",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",     "value": "http://localhost:3000", "type": "string" },
    { "key": "adminApiKey", "value": "replace-me-with-openssl-rand-hex-32", "type": "string" },
    { "key": "productId",   "value": "rose-face-serum", "type": "string" }
  ],
  "item": [
    {
      "name": "Products",
      "description": "Public product endpoints — no auth required.",
      "item": [
        {
          "name": "GET all products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products"]
            },
            "description": "Returns all active products ordered by sort_order then created_at."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Body has data array', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('data');",
                  "  pm.expect(json.data).to.be.an('array');",
                  "});",
                  "pm.test('Rate-limit headers present', () => {",
                  "  pm.response.to.have.header('X-RateLimit-Limit');",
                  "  pm.response.to.have.header('X-RateLimit-Remaining');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "GET all products — filtered by category",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products?category=serums",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products"],
              "query": [{ "key": "category", "value": "serums" }]
            },
            "description": "Returns only products in the 'serums' category."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('All returned products match category', () => {",
                  "  const json = pm.response.json();",
                  "  json.data.forEach(p => pm.expect(p.category).to.equal('serums'));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "GET product by ID — valid",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", "{{productId}}"]
            },
            "description": "Returns full product detail for a given slug ID."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Body has data object with id', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.data).to.have.property('id');",
                  "  pm.expect(json.data).to.have.property('price');",
                  "  pm.expect(json.data).to.have.property('description');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "GET product by ID — not found",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products/this-does-not-exist",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", "this-does-not-exist"]
            },
            "description": "Expects a 404 for a slug that doesn't exist in the DB."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 404', () => pm.response.to.have.status(404));",
                  "pm.test('Error message present', () => {",
                  "  pm.expect(pm.response.json()).to.have.property('error');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "GET product by ID — invalid slug format",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products/INVALID ID!!",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", "INVALID ID!!"]
            },
            "description": "Slug with uppercase / special characters should return 400."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 400', () => pm.response.to.have.status(400));",
                  "pm.test('Error message about format', () => {",
                  "  pm.expect(pm.response.json().error).to.include('Invalid product ID format');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Orders",
      "description": "Public order creation endpoint.",
      "item": [
        {
          "name": "POST create order — valid",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Fatema Khanam\",\n  \"phone\": \"01712345678\",\n  \"address\": \"123 Mirpur Road, Dhaka\",\n  \"email\": \"fatema@example.com\",\n  \"note\": \"Please call before delivery.\",\n  \"deliveryZone\": \"inside-dhaka\",\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 2\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders"]
            },
            "description": "Creates a new order. Server recomputes totals from DB price — client price is never trusted."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Returned order has expected fields', () => {",
                  "  const d = pm.response.json().data;",
                  "  pm.expect(d).to.have.property('id');",
                  "  pm.expect(d).to.have.property('total');",
                  "  pm.expect(d).to.have.property('status');",
                  "  pm.expect(d.status).to.equal('pending');",
                  "  pm.expect(d.deliveryCharge).to.equal(50);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
