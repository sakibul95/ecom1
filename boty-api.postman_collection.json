    {
      "name": "Admin — Products",
      "description": "Key-gated endpoint for uploading products.\nRequires Authorization: Bearer {{adminApiKey}}",
      "item": [
        {
          "name": "POST upload product — valid (full payload)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminApiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"rose-face-serum\",\n  \"name\": \"Rose Face Serum\",\n  \"description\": \"A lightweight serum packed with rose extract for deep hydration.\",\n  \"tagline\": \"Glow from within\",\n  \"price\": 499,\n  \"originalPrice\": 699,\n  \"discount\": 28,\n  \"image\": \"/images/rose-face-serum.jpg\",\n  \"badge\": \"Best Seller\",\n  \"category\": \"serums\",\n  \"defaultQty\": 1,\n  \"sizes\": [\"30ml\", \"50ml\"],\n  \"details\": \"Enriched with natural rose extracts and hyaluronic acid.\",\n  \"howToUse\": \"Apply 2-3 drops on clean skin before moisturiser.\",\n  \"ingredients\": \"Rosa Damascena, Hyaluronic Acid, Niacinamide\",\n  \"deliveryInfo\": \"Delivered within 3-5 business days.\",\n  \"sortOrder\": 1,\n  \"isActive\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/products",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "products"]
            },
            "description": "Creates a product with all optional fields filled in."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const status = pm.response.code;",
                  "pm.test('Status is 201 or 409 (conflict if already exists)', () => {",
                  "  pm.expect([201, 409]).to.include(status);",
                  "});",
                  "if (status === 201) {",
                  "  pm.test('Returned product has id and price', () => {",
                  "    const d = pm.response.json().data;",
                  "    pm.expect(d.id).to.equal('rose-face-serum');",
                  "    pm.expect(d.price).to.equal(499);",
                  "  });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST upload product — minimal required fields only",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminApiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"minimal-product\",\n  \"name\": \"Minimal Product\",\n  \"description\": \"Just the required fields.\",\n  \"price\": 150,\n  \"image\": \"/images/minimal.jpg\",\n  \"category\": \"moisturizers\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/products",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "products"]
            },
            "description": "Only required fields — optional fields should default gracefully."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201 or 409', () => {",
                  "  pm.expect([201, 409]).to.include(pm.response.code);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST upload product — duplicate ID (409 conflict)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminApiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"rose-face-serum\",\n  \"name\": \"Duplicate Product\",\n  \"description\": \"This ID already exists.\",\n  \"price\": 299,\n  \"image\": \"/images/dup.jpg\",\n  \"category\": \"serums\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/products",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "products"]
            },
            "description": "Sending the same ID twice — second request must return 409."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 409', () => pm.response.to.have.status(409));",
                  "pm.test('Error mentions already exists', () => {",
                  "  pm.expect(pm.response.json().error).to.include('already exists');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
